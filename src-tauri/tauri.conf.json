{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Birds Eye",
  "version": "0.1.0",
  "identifier": "dev.birdseye.desktop",
  "build": {
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../workspace" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../workspace" },
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../workspace/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Birds Eye",
        "width": 1440,
        "height": 960,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:5174",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
